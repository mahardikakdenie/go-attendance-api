                    "$ref": "#/definitions/model.Meta"
                }
            }
        },
        "model.AttendanceRequest": {
            "type": "object",
            "required": [
                "action",
                "latitude",
                "longitude"
            ],
            "properties": {
                "action": {
                    "enum": [
                        "clock_in",
                        "clock_out"
                    ],
                    "allOf": [
                        {
                            "$ref": "#/definitions/model.AttendanceAction"
                        }
                    ],
                    "example": "clock_in"
                },
                "latitude": {
                    "type": "number",
                    "example": -6.1339179
                },
                "longitude": {
                    "type": "number",
                    "example": 106.8329504
                },
                "media_url": {
                    "type": "string",
                    "example": "https://i.pinimg.com/control1/736x/41/e7/99/41e799436291fdfb4c969b80913a19fe.jpg"
                }
            }
        },
        "model.BaseResponse": {
