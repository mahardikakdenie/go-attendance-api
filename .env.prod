# Database Configuration
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=admin
DB_NAME=attendance_db

# Redis Configuration
REDIS_ADDR=redis:6379
REDIS_PASSWORD=

# App Configuration
APP_PORT=8002
GIN_MODE=release
RUN_MIGRATION=true
RUN_SEEDER=true
RESET_DB=false

# Docker Hub Configuration
DOCKER_IMAGE_NAME=kucingemas/go-attendance-api
DOCKER_IMAGE_TAG=latest

# API Keys (Isi di GitHub Secrets)
IMGBB_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
